{
  "name": "createrington-kubejs",
  "version": "1.0.0",
  "description": "Version-controlled KubeJS scripts for the Createrington server",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "kubejs build && node scripts/copy-data.js",
    "watch": "kubejs build --watch",
    "pull": "node scripts/pull.js",
    "push": "node scripts/push.js",
    "status": "node scripts/status.js",
    "extract-tags": "node scripts/extract-tags.js",
    "deploy-local": "node scripts/deploy-local.js",
    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"lib/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\" \"scripts/**/*.js\" \"lib/**/*.js\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@kubejs/plugin": "^1.2.11",
    "adm-zip": "^0.5.16",
    "chalk": "^4.1.2",
    "dotenv": "^16.4.7",
    "ora": "^5.4.1",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "**/*.{ts,js,json,md}": "prettier --write"
  }
}
